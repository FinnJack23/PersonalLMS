# Personal LMS environment variables — names only. Never commit real values.

# Local inference (Tier 1) — wired up in a later commit.
OLLAMA_BASE_URL=

# Hosted inference (Tier 2) — wired up only after the escalation policy and
# budget controls are implemented.
HOSTED_MODEL_API_KEY=

# Obsidian vault access — wired up in the Obsidian safe-access layer.
OBSIDIAN_VAULT_PATH=

# Runtime database (SQLite catalog and state).
PERSONAL_LMS_DATABASE_URL=

# CrewAI orchestration adapter — the personal-lms code sets safe defaults
# (tracing=False, suppress_flow_events=True) regardless of these, but they
# are documented here for anyone running crewai directly or overriding those
# defaults. CrewAI emits anonymous telemetry via OpenTelemetry by default;
# this disables it entirely so no data leaves the machine.
OTEL_SDK_DISABLED=true
# OTEL_SDK_DISABLED alone is not sufficient for fully offline/hermetic runs:
# CrewAI also performs a PyPI network call to check for a newer version, and
# writes a local first-run tracing-consent file, independently of the OTel
# setting above. These three additionally close those paths:
CREWAI_DISABLE_VERSION_CHECK=true
CREWAI_TRACING_ENABLED=false
CREWAI_DISABLE_TRACKING=true
